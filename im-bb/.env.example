# Information Mediator Building Block (IM-BB) Configuration
# GovStack compliant X-Road based service mesh

# X-Road Configuration
XROAD_TOKEN_PIN=1234567890
XROAD_ADMIN_USER=xrd
XROAD_ADMIN_PASSWORD=change-this-in-production

# Database
XROAD_DB_HOST=xroad-db
XROAD_DB_PORT=5432
XROAD_DB_USER=xroad
XROAD_DB_PWD=change-this-in-production

# Instance Identifier (Adjust for your country)
# Format: COUNTRY/ORGANIZATION/INSTANCE
INSTANCE_IDENTIFIER=SN/GOV/SENRM

# Central Server (for production)
CENTRAL_SERVER_URL=https://central-server.govstack.global

# Security Server Instance
SECURITY_SERVER_CODE=IM-BB-01
SECURITY_SERVER_OWNER=SENRM

# Ports
SECURITY_SERVER_PORT=8080
ADMIN_UI_PORT=8443
MESSAGE_EXCHANGE_PORT=5500

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Log Level (DEBUG, INFO, WARN, ERROR)
XROAD_LOG_LEVEL=INFO

# TLS/SSL Configuration (Production)
TLS_CERT_PATH=/etc/xroad/ssl/cert.pem
TLS_KEY_PATH=/etc/xroad/ssl/key.pem
