# API Gateway Environment Variables
# Copy this file to .env and update the values

# JWT Secret (must match across all Building Blocks)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Building Block URLs (for direct communication)
IDENTITY_BB_URL=http://localhost:3000
PAYMENT_BB_URL=http://localhost:3001

# Information Mediator (Production)
USE_IM_BB=false
IM_BB_URL=https://im-bb.senrm.gov.sn

# API Gateway
API_GATEWAY_PORT=8080
