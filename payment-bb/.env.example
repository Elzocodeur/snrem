# Database
DATABASE_URL="file:./dev.db"

# JWT Configuration (should match identity-bb for interoperability)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Server Configuration
PORT=3001
NODE_ENV=development

# Payment Providers
# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Wave (Mobile Money Senegal)
WAVE_API_KEY=""
WAVE_SECRET_KEY=""
WAVE_WEBHOOK_SECRET=""

# Orange Money
ORANGE_MONEY_API_KEY=""
ORANGE_MONEY_SECRET_KEY=""

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# Identity BB Integration (OIDC)
IDENTITY_BB_URL="http://localhost:3000"
IDENTITY_BB_CLIENT_ID=""
IDENTITY_BB_CLIENT_SECRET=""

# Application URLs
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:4200"

# Currency
DEFAULT_CURRENCY="XOF"
SUPPORTED_CURRENCIES="XOF,EUR,USD"
